<?xml version="1.0" encoding="utf-8"?>
<!--
    Dark "liquid glass" background.

    Four stacked layers simulate the effect:
      1. Translucent dark base  — lets the wallpaper colour bleed through (~30 %)
      2. Diagonal surface shimmer — the bright light catch on the glass face
      3. Top-edge inner glow   — simulates glass "lip" / refraction at the rim
      4. Bright outer rim      — the sharp edge you see on real glass
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1 · Translucent dark base (≈ 69 % opaque charcoal) -->
    <item>
        <shape>
            <solid android:color="#B0111418" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- 2 · Diagonal surface shimmer — bright top-left fading to transparent -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:centerColor="#0AFFFFFF"
                android:endColor="#00FFFFFF"
                android:startColor="#24FFFFFF"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- 3 · Top-edge inner glow (angle=90 → bright at top, gone at bottom) -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#16FFFFFF"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- 4 · Bright glass rim -->
    <item>
        <shape>
            <solid android:color="#00000000" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#55FFFFFF" />
        </shape>
    </item>

</layer-list>
