<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <!-- Subtle dark fill so the circle is visible even if the widget background
         fails to render (e.g. on very light launchers). -->
    <solid android:color="#33000000" />
    <stroke
        android:width="2dp"
        android:color="#CCFFFFFF" />
</shape>
