<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Dark translucent base, close to the shared reference image. -->
    <item>
        <shape>
            <solid android:color="#B01F231F" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Soft green/white highlight passing through the glass. -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:centerColor="#1228FF7A"
                android:endColor="#00FFFFFF"
                android:startColor="#30FFFFFF"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Inner top shine. -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#26FFFFFF"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Bright rim. -->
    <item>
        <shape>
            <solid android:color="#00000000" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#70FFFFFF" />
        </shape>
    </item>

</layer-list>
